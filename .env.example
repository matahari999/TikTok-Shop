VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_ADMIN_EMAIL=your_email@example.com

# ── Zalo ──────────────────────────────────────────────────────────────
# Zalo OA 플로팅 버튼 — OA ID를 입력하면 버튼이 활성화됨 (미입력 시 숨김)
# Zalo OA 관리자 페이지 → OA 정보 → OA ID 확인
VITE_ZALO_OA_ID=

# Zalo OAuth 로그인 — App ID (developers.zalo.me에서 확인)
# 미입력 시 로그인 화면에서 Zalo 버튼 숨김
# ⚠️ App Secret은 여기에 넣지 말 것 — Supabase Edge Function Secret으로 설정:
#    supabase secrets set ZALO_APP_ID=xxx ZALO_APP_SECRET=yyy
VITE_ZALO_APP_ID=

# 사이트 공개 URL — QR 코드 생성에 사용 (미입력 시 현재 도메인으로 자동 설정)
# 예: https://tiktok-shop-vn.vercel.app
VITE_SITE_URL=

# MoMo payment (optional — leave blank until ready to integrate)
VITE_MOMO_PARTNER_CODE=
VITE_MOMO_ACCESS_KEY=

# VNPay payment (optional — leave blank until ready to integrate)
VITE_VNPAY_TMN_CODE=
VITE_VNPAY_HASH_SECRET=
